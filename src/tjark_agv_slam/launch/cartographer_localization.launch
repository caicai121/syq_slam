<launch>

  <!-- ============================================================ -->
  <!-- Cartographer Localization: 在已有地图上定位                    -->
  <!--                                                              -->
  <!-- Prerequisites:                                               -->
  <!--   source ~/cartographer_ws/install_isolated/setup.bash       -->
  <!--   source ~/catkin_ws/devel/setup.bash                        -->
  <!--   roslaunch tjark_agv_slam cartographer_localization.launch  -->
  <!--                                                              -->
  <!-- 启动后需要手动冻结轨迹：                                      -->
  <!--   rosservice call /start_trajectory                           -->
  <!-- ============================================================ -->

  <arg name="use_sim_time" default="true"/>
  <arg name="configuration_basename" default="tjark_agv_2d_localization.lua"/>
  <arg name="rviz" default="true"/>
  <arg name="teleop" default="true"/>
  <arg name="pbstream_file" default="$(find tjark_agv_slam)/maps/map.pbstream"/>

  <!-- 1. Use simulation time -->
  <param name="/use_sim_time" value="$(arg use_sim_time)" />

  <!-- 2. Load robot description -->
  <param name="robot_description"
         command="$(find xacro)/xacro $(find tjark_agv)/urdf/tjark_agv.xacro" />

  <!-- 3. Start Gazebo with the same world -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find tjark_agv_slam)/worlds/boxhouse_square_maze.world" />
    <arg name="paused" value="false" />
    <arg name="use_sim_time" value="$(arg use_sim_time)" />
    <arg name="gui" value="true" />
    <arg name="headless" value="false" />
    <arg name="debug" value="false" />
  </include>

  <!-- 4. Spawn robot (delay 5s for Gazebo ready) -->
  <node name="spawn_model"
        pkg="gazebo_ros"
        type="spawn_model"
        args="-urdf -model tjark_agv -param robot_description -x -2 -y 0 -z 0.4"
        output="screen"
        launch-prefix="bash -c 'sleep 5; $0 $@' " />

  <!-- 6. Robot state publisher -->
  <node name="robot_state_publisher"
        pkg="robot_state_publisher"
        type="robot_state_publisher" />

  <!-- 7a. Odom timestamp filter -->
  <node name="odom_time_filter"
        pkg="tjark_agv_slam"
        type="odom_time_filter.py"
        output="screen" />

  <!-- 7b. Cartographer node (localization mode) -->
  <node name="cartographer_node"
        pkg="cartographer_ros"
        type="cartographer_node"
        args="-configuration_directory $(find tjark_agv_slam)/config
              -configuration_basename $(arg configuration_basename)
              -load_state_filename $(arg pbstream_file)"
        output="screen">

    <remap from="scan" to="/scan" />
    <remap from="odom" to="/odom_filtered" />

  </node>

  <!-- 8. Occupancy grid node -->
  <node name="cartographer_occupancy_grid_node"
        pkg="cartographer_ros"
        type="cartographer_occupancy_grid_node"
        args="-resolution 0.05 -publish_period_sec 1.0"
        output="screen" />

  <!-- 9. Teleop keyboard -->
  <node if="$(arg teleop)"
        name="teleop"
        pkg="teleop_twist_keyboard"
        type="teleop_twist_keyboard.py"
        launch-prefix="gnome-terminal --" />

  <!-- 10. RViz -->
  <node if="$(arg rviz)"
        name="rviz"
        pkg="rviz"
        type="rviz"
        args="-d $(find tjark_agv_slam)/rviz/cartographer.rviz" />

</launch>
