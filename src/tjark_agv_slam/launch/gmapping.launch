<launch>
  <!-- ============================================================ -->
  <!-- Gmapping Laser SLAM with tjark_agv in Boxhouse (Gazebo)    -->
  <!--                                                              -->
  <!-- Usage:                                                       -->
  <!--   source ~/catkin_ws/devel/setup.bash                        -->
  <!--   roslaunch tjark_agv_slam gmapping.launch                   -->
  <!-- ============================================================ -->

  <!-- 1. Load robot description -->
  <param name="robot_description"
         command="$(find xacro)/xacro $(find tjark_agv_slam)/urdf/tjark_agv_slam.xacro" />

  <!-- 2. Start Gazebo with Boxhouse world -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find tjark_agv_slam)/worlds/boxhouse_square_maze.world" />
    <arg name="paused" value="false" />
    <arg name="use_sim_time" value="true" />
    <arg name="gui" value="true" />
    <arg name="headless" value="false" />
    <arg name="debug" value="false" />
  </include>

  <!-- 3. Spawn robot (delay 5s for Gazebo ready) -->
  <node name="spawn_model" pkg="gazebo_ros" type="spawn_model"
        args="-urdf -model tjark_agv -param robot_description -x -2 -y 0 -z 0.4"
        output="screen"
        launch-prefix="bash -c 'sleep 5; $0 $@' " />

  <!-- 5. Robot state publisher -->
  <node name="robot_state_publisher" pkg="robot_state_publisher"
        type="robot_state_publisher" />

  <!-- 6. Gmapping -->
  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
    <param name="maxUrange" value="6.0"/>
    <param name="maxRange" value="12.0"/>
    <param name="delta" value="0.05"/>
    <param name="xmin" value="-10"/>
    <param name="xmax" value="10"/>
    <param name="ymin" value="-10"/>
    <param name="ymax" value="10"/>
    <!-- More frequent scan matching to prevent rotational drift -->
    <param name="linearUpdate" value="0.2"/>
    <param name="angularUpdate" value="0.1"/>
    <param name="temporalUpdate" value="0.5"/>
    <param name="particles" value="120"/>
    <param name="minimumScore" value="60"/>
    <param name="map_update_interval" value="1.0"/>
    <!-- Lower motion model noise: trust accurate odom more -->
    <param name="srr" value="0.01"/>
    <param name="srt" value="0.02"/>
    <param name="str" value="0.01"/>
    <param name="stt" value="0.02"/>
    <param name="odom_frame" value="odom"/>
    <param name="map_frame" value="map"/>
  </node>

  <!-- 7. Teleop keyboard (opens in a new terminal) -->
  <node name="teleop" pkg="teleop_twist_keyboard" type="teleop_twist_keyboard.py"
        launch-prefix="gnome-terminal --" />

  <!-- 8. RViz with pre-configured map display -->
  <node name="rviz" pkg="rviz" type="rviz"
        args="-d $(find tjark_agv_slam)/rviz/gmapping.rviz" />

</launch>
