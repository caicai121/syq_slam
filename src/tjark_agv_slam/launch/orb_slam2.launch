<launch>
  <!-- ============================================================ -->
  <!-- ORB-SLAM2 RGB-D with tjark_agv in Rich Boxhouse (Gazebo)   -->
  <!--                                                              -->
  <!-- Usage:                                                       -->
  <!--   source ~/catkin_ws/devel/setup.bash                        -->
  <!--   roslaunch tjark_agv_slam orb_slam2.launch                  -->
  <!--                                                              -->
  <!-- Control robot in another terminal:                           -->
  <!--   rosrun teleop_twist_keyboard teleop_twist_keyboard.py      -->
  <!-- ============================================================ -->

  <!-- 1. Load robot description (xacro + camera override) -->
  <param name="robot_description"
         command="$(find xacro)/xacro $(find tjark_agv_slam)/urdf/tjark_agv_slam.xacro" />

  <!-- 2. Start Gazebo with Rich Boxhouse world -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find tjark_agv_slam)/worlds/boxhouse_builtin.world" />
    <arg name="paused" value="false" />
    <arg name="use_sim_time" value="true" />
    <arg name="gui" value="true" />
    <arg name="headless" value="false" />
    <arg name="debug" value="false" />
  </include>

  <!-- 3. Static TF -->
  <node name="tf_footprint_base" pkg="tf" type="static_transform_publisher"
        args="0 0 0 0 0 0 base_link base_footprint 40" />

  <!-- 4. Spawn robot in room center (delay 5s for Gazebo ready) -->
  <node name="spawn_model" pkg="gazebo_ros" type="spawn_model"
        args="-urdf -model tjark_agv -param robot_description -x -2 -y 0 -z 0.1"
        output="screen"
        launch-prefix="bash -c 'sleep 5; $0 $@' " />

  <!-- 5. Robot state publisher -->
  <node name="robot_state_publisher" pkg="robot_state_publisher"
        type="robot_state_publisher" />

  <!-- 6. Depth filter: remove NaN/inf from Gazebo depth images -->
  <node name="depth_filter" pkg="tjark_agv_slam" type="depth_filter.py" output="screen" />

  <!-- 7. ORB-SLAM2 RGB-D (delay 10s for camera to be ready) -->
  <node name="orb_slam2_rgbd" pkg="ORB_SLAM2" type="RGBD" output="screen"
        args="$(env HOME)/catkin_ws/src/ORB_SLAM2/Vocabulary/ORBvoc.txt
              $(find tjark_agv_slam)/config/orb_slam2_tjark.yaml"
        launch-prefix="bash -c 'sleep 3; $0 $@' ">
    <remap from="/camera/rgb/image_raw" to="/my_camera/color/image_raw" />
    <remap from="/camera/depth_registered/image_raw" to="/my_camera/depth/image_filtered" />
  </node>

  <!-- 8. Teleop keyboard (opens in a new terminal) -->
  <node name="teleop" pkg="teleop_twist_keyboard" type="teleop_twist_keyboard.py"
        launch-prefix="gnome-terminal --" />

</launch>
